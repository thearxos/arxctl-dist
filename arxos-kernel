#!/usr/bin/env bash
# arxos-kernel — fetch / list / install ARXOS kernels from the official GitHub build repo.
# Each kernel version is a GitHub Release (tag = "<kernel>-<version>", assets = the .pkg.tar.zst).
# This backs the Control Center Kernels tab: get-latest, version history, and rollback.
#   arxos-kernel list    <linux-arxos|linux-arxos-zen>          # versions, newest first
#   arxos-kernel latest  <kernel>                               # newest version tag
#   arxos-kernel current <kernel>                               # installed version (or empty)
#   arxos-kernel install <kernel> [version]                     # install latest, or a specific one (rollback)
set -uo pipefail
REPO="${ARXOS_KERNEL_REPO:-thearxos/arxos-kernels}"
API="https://api.github.com/repos/$REPO/releases?per_page=100"
DL="https://github.com/$REPO/releases/download"                # full history: every version (rollback)
R2_DL="${ARXOS_KERNEL_R2:-https://pub-d5ff3efb1d204998aa120ded02d070b9.r2.dev/kernels}"  # latest only (fast)

_json(){ curl -fsSL -H "Accept: application/vnd.github+json" "$API" 2>/dev/null; }

list(){   # tags for a kernel, newest first; require a DIGIT right after "<k>-" so linux-arxos does
          # not also match linux-arxos-zen (whose version part starts with "zen")
  _json | python3 -c "import sys,json;k=sys.argv[1];print('\n'.join(r['tag_name'] for r in json.load(sys.stdin) if r.get('tag_name','').startswith(k+'-') and r['tag_name'][len(k)+1:len(k)+2].isdigit()))" "$1" 2>/dev/null
}
latest(){ list "$1" | head -1; }
current(){ pacman -Q "$1" 2>/dev/null | awk '{print $2}'; }

install(){
  local k="$1" tag="${2:-}"
  [ -n "$tag" ] || tag="$(latest "$k")"
  [ -n "$tag" ] || { echo "!! no release for $k on $REPO"; return 1; }
  local ver="${tag#${k}-}" tmp; tmp="$(mktemp -d)"
  # latest lives on R2 (fast, pruned-to-latest); older versions (rollback) come from GitHub's full history
  local src base
  if [ "$tag" = "$(latest "$k")" ]; then src=R2; base="$R2_DL"; else src=GitHub; base="$DL/$tag"; fi
  echo ">> fetching $k $ver from $src ..."
  curl -fL --progress-bar -o "$tmp/$k.pkg.tar.zst"      "$base/$k-$ver-x86_64.pkg.tar.zst"        || { echo "!! download failed ($src)"; return 1; }
  curl -fL --progress-bar -o "$tmp/$k-hdr.pkg.tar.zst"  "$base/$k-headers-$ver-x86_64.pkg.tar.zst" || { echo "!! headers download failed ($src)"; return 1; }
  sudo pacman -U --noconfirm "$tmp/$k.pkg.tar.zst" "$tmp/$k-hdr.pkg.tar.zst" || { echo "!! install failed"; return 1; }
  sudo mkinitcpio -P; sudo grub-mkconfig -o /boot/grub/grub.cfg
  rm -rf "$tmp"; echo ">> installed $k $ver — reboot or Set default in the Control Center"
}

case "${1:-}" in
  list)    list "${2:?kernel}" ;;
  latest)  latest "${2:?kernel}" ;;
  current) current "${2:?kernel}" ;;
  install) install "${2:?kernel}" "${3:-}" ;;
  *) echo "usage: arxos-kernel {list|latest|current|install} <linux-arxos|linux-arxos-zen> [version]"; exit 1 ;;
esac
