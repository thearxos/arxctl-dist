]

def _daypart(h):
    if 5 <= h < 12:  return "morning"
    if 12 <= h < 17: return "afternoon"
    if 17 <= h < 22: return "evening"
    return "night"

def fetch_weather():
    """(city, temp_C, desc) from wttr.in, honoring ~/.config/arxos/location, else IP geo."""
    loc = ""
    try:
        lf = os.path.expanduser("~/.config/arxos/location")
        if os.path.exists(lf): loc = open(lf).read().strip()
    except Exception: pass
    url = ("https://wttr.in/%s?format=j1" % urllib.parse.quote(loc)) if loc else "https://wttr.in/?format=j1"
    req = urllib.request.Request(url, headers={"User-Agent": "curl/8"})
    d = json.load(urllib.request.urlopen(req, timeout=8))
    cur = d["current_condition"][0]
    area = (d.get("nearest_area") or [{}])[0]
    city = ((area.get("areaName") or [{}])[0].get("value", "") if area else "") or loc
    return city, cur.get("temp_C", ""), (cur.get("weatherDesc") or [{}])[0].get("value", "")

def greeting_text(city=None, temp=None, desc=None):
    base = random.choice(GREETINGS[_daypart(datetime.datetime.now().hour)])
    if not desc:
        return base + " · welcome back"
    flavor = next((f for k, f in WEATHER_FLAVOR if k in desc.lower()), "it's " + desc.lower().strip())
    loc = (" in %s" % city) if city else ""
    if temp not in (None, "", "?"):
        return "%s · %s%s, %s°C" % (base, flavor, loc, temp)
    return "%s · %s%s" % (base, flavor, loc)

def run_win(title, cmd, privileged=False):
    win = Gtk.Window(title=title); win.set_default_size(680, 470); win.set_position(Gtk.WindowPosition.CENTER)
    try: win.set_icon_name("utilities-system-monitor")
    except Exception: pass
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    for m in ("set_margin_top","set_margin_bottom","set_margin_start","set_margin_end"): getattr(box, m)(14)
    tl = Gtk.Label(); tl.set_markup("<b>%s</b>" % title); tl.set_xalign(0); box.pack_start(tl, False, False, 0)
    tv = Gtk.TextView(); tv.set_editable(False); tv.set_cursor_visible(False); tv.set_monospace(True); tv.get_style_context().add_class("mono")
    sc = Gtk.ScrolledWindow(); sc.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC); sc.add(tv); box.pack_start(sc, True, True, 0)
    cb = Gtk.Button(label="Working…"); cb.set_sensitive(False); cb.connect("clicked", lambda *_: win.destroy()); box.pack_start(cb, False, False, 0)
    win.add(box); win.show_all(); buf = tv.get_buffer()
    full = ("pkexec bash -lc %s" if privileged else "bash -lc %s") % shlex.quote(cmd)
    def append(t):
        buf.insert(buf.get_end_iter(), t); tv.scroll_to_iter(buf.get_end_iter(), 0, False, 0, 0); return False
    def reader():
        try:
            pr = subprocess.Popen(full, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
            for line in pr.stdout:
                GLib.idle_add(append, re.sub(r'\x1b\[[0-9;?]*[a-zA-Z]', '', line))
            pr.wait()
        except Exception as e:
            GLib.idle_add(append, "\nerror: %s\n" % e)
        GLib.idle_add(append, "\n— finished —\n")
        GLib.idle_add(lambda: (cb.set_label("Close"), cb.set_sensitive(True)) and False)
        try: check_updates()   # re-check after any update/install/remove so the counter is accurate
        except Exception: pass
    threading.Thread(target=reader, daemon=True).start()

# term() now runs the command in a live GUI window (never a terminal)
def term(cmd):
    cmd = re.sub(r'\s*;\s*echo\s*;\s*read[^\n]*$', '', cmd)
    cmd = re.sub(r'\s*;\s*read[^\n]*$', '', cmd)
    privileged = cmd.lstrip().startswith("sudo ")
    if privileged: cmd = cmd.lstrip()[5:]
    title = (cmd.strip().split() or ["ARXOS"])[0]
    run_win(title, cmd, privileged=privileged)

def priv(cmd):
    run_win("ARXOS", cmd, privileged=True)

_prev = [0, 0]
def cpu_pct():
    try:
        with open('/proc/stat') as f: v = list(map(int, f.readline().split()[1:]))
        idle = v[3] + (v[4] if len(v) > 4 else 0); total = sum(v)
        di = idle - _prev[0]; dt = total - _prev[1]; _prev[0] = idle; _prev[1] = total
        return None if dt <= 0 else max(0, min(100, round((1 - di/dt) * 100)))
    except Exception: return None

def last_mod():
    try:
        d = time.time() - os.path.getmtime('/var/lib/pacman/local')
        if d < 90: return "just now"
        if d < 3600: return "%dm ago" % (d/60)
        if d < 86400: return "%dh ago" % (d/3600)
        return "%dd ago" % (d/86400)
    except Exception: return "?"

UPD = "/tmp/.arxctl_updates"
def count_tool_updates():
    """ArxOS tool updates: manifest repos whose remote HEAD differs from what is installed."""
    n = 0
    manifest = os.environ.get("ARXOS_MANIFEST", "/etc/arxos/repos.list")
    cache = os.path.join(os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "arxos", "repos")
    try: mlines = open(manifest).read().splitlines()
    except Exception: return 0
    for ln in mlines:
        ln = ln.strip()
        if not ln or ln.startswith("#"): continue
        p = ln.split()
        if len(p) < 2 or not p[1].startswith("https://"): continue
        branch = p[2] if len(p) > 2 else "main"
        d = os.path.join(cache, p[0])
        if not os.path.isdir(os.path.join(d, ".git")): n += 1; continue   # not installed yet
        # env -u neutralizes any leaked GIT_DIR; -C uses the repo's own origin remote
        g = "env -u GIT_DIR -u GIT_WORK_TREE git -C %s " % shlex.quote(d)
        loc = sh(g + "rev-parse HEAD 2>/dev/null")
        rem = sh(g + "ls-remote origin %s 2>/dev/null" % shlex.quote(branch)).split()
        if loc and rem and rem[0] != loc: n += 1
    return n
def check_updates():
    def run():
        try:
            # Actionable updates = repo + AUR packages (minus IgnorePkg) PLUS ArxOS tool
            # updates (manifest repos with new commits), so the counter matches the news.
            ign = set(sh("pacman-conf IgnorePkg 2>/dev/null").split())
            lines = sh("checkupdates 2>/dev/null").splitlines()
            if sh("command -v yay"): lines += sh("yay -Qua 2>/dev/null").splitlines()
            names = {p.split()[0] for p in lines if p.split()}
            names -= ign
            open(UPD, "w").write(str(len(names) + count_tool_updates()))
            # also check ARXOS news (new tool commits) -> right-side popups
            try: subprocess.Popen(["arxos-news", "--quiet"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except Exception: pass
        except Exception: pass
    threading.Thread(target=run, daemon=True).start()
def updates_count():
    try: return int(open(UPD).read().strip())
    except Exception: return None

NET = "/tmp/.arxctl_net"
def check_net():
    def run():
        import re
        j = sh("curl -s --max-time 7 https://check.torproject.org/api/ip 2>/dev/null")
        istor = "1" if '"IsTor":true' in j else "0"
        m = re.search(r'"IP":"([^"]+)"', j); ip = m.group(1) if m else ""
        if not ip: ip = sh("curl -s --max-time 7 https://api.ipify.org")
        try: open(NET,"w").write(istor + " " + (ip or "?"))
        except Exception: pass
    threading.Thread(target=run, daemon=True).start()
def net_info():
    try:
        a = open(NET).read().split(); return (a[0] == "1"), (a[1] if len(a) > 1 else "")
    except Exception: return None, ""

