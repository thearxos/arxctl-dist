GREETINGS = {
    "morning":   ["Good morning", "Morning", "Rise and shine"],
    "afternoon": ["Good afternoon", "Afternoon", "Hope the day's treating you well"],
    "evening":   ["Good evening", "Evening", "Winding down for the day"],
