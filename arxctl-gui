WEATHER_FLAVOR = [
    ("sun", "the sun is shining"), ("clear", "clear skies out there"),
    ("partly", "a little cloudy out"), ("cloud", "cloudy outside"),
    ("overcast", "grey skies today"), ("drizzle", "a light drizzle outside"),
